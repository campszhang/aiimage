# ==========================================
# 家居软品 AI 生图工具 - 环境变量
# ==========================================
# 部署到服务器时，把这个文件复制为 .env 并填入真实值
# 命令: cp .env.example .env
#
# 注意：Gemini API key 不在 env 里 —— 第一次部署登录 admin →
# 系统设置 → 填入即可（存到 SQLite settings 表，重启不丢）。
# ==========================================

# 域名（例如 ai-tool.yourdomain.com）
# 必须已经解析到 VM 的公网 IP
DOMAIN=

# Caddy 自动申请 HTTPS 证书时用的邮箱
# 填你能收邮件的邮箱，Let's Encrypt 会发送证书过期提醒
ADMIN_EMAIL=admin@example.com

# ==========================================
# 账号登录相关
# ==========================================

# 会话加密密钥，至少 32 个字符
# 生成方法（在 SSH 终端里跑）：openssl rand -hex 32
# 这个值泄露后所有登录会话都会失效（需要重新登录），注意保密
SESSION_SECRET=

# 首次启动时自动创建的管理员账号（如果数据库里还没有任何用户）
# 建议先用强密码，登录后在"用户管理"页面改密码或加新成员
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# ==========================================
# 专属云储存
# ==========================================

# 图片上传接口。系统设置里的 cloud_storage_upload_url 优先级更高；
# 这里作为首次启动/兜底默认值。
CLOUD_STORAGE_UPLOAD_URL=http://35.212.172.128:8082/upload-image
CLOUD_STORAGE_FILE_FIELD=image
CLOUD_STORAGE_TIMEOUT_MS=12000
